{
  "name": "@medyll/idae-csss",
  "bin": {
    "add-skill": "./dist/cli/add-skill.js"
  },
  "version": "0.0.1",
  "description": "CSS and Style utility library for the Idae ecosystem.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "package:watch": "svelte-kit sync && svelte-package --watch",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "",
    "prepackage": "node scripts/package-pre.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "keywords": [
    "idae",
    "css",
    "scss",
    "utility",
    "typescript",
    "svelte",
    "unocss"
  ],
  "author": "Lebrun Meddy",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "scope": "medyll",
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@medyll/idae-config-prettier": "latest",
    "@medyll/idae-eslint-config": "workspace:*",
    "@medyll/idae-shared": "workspace:*",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "postcss": "^8.5.8",
    "publint": "^0.3.18",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@medyll/skiller": "workspace:*",
    "command": "^1.1.1",
    "commander": "^14.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medyll/idae.git"
  },
  "publishConfig": {
    "access": "public",
    "directory": "."
  }
}
