{
  "name": "@medyll/idae-html",
  "description": "Raw HTML utility library for dynamic web apps/sites (client & client-server), inspired by Svelte/React but builderless. Provides advanced HTML generation, parsing, and manipulation in JS/TS. Integrates with @medyll/idae-dom-events, idae-idbql, and @medyll/idae-stator (monorepo).",
  "bin": {
    "idae-html": "./cli.cjs"
  },
  "version": "1.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medyll/idae.git"
  },
  "scripts": {
    "dev": "node scripts/server/idae-server.js",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "node scripts/build/copy-components.js && node scripts/build/transpile-html-scripts.js && npm run build:types && publint",
    "prepublishOnly": "npm run package",
    "check": "tsc -p ./tsconfig.json --noEmit",
    "check:watch": "tsc -p ./tsconfig.json --noEmit --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "prepackage": "node scripts/package-pre.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build:dist": "node scripts/build/build-resizePanel.js",
    "build:html": "node scripts/build/build-html-component.js",
    "build:html:all": "node scripts/build/build-html-all.js",
    "test": ""
  },
  "vitest": {
    "include": [
      "test/**/*.test.js",
      "scripts/server/test-server-slots.js"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "svelte": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "."
  },
  "devDependencies": {
    "@medyll/idae-be": "workspace:*",
    "@medyll/idae-config-prettier": "workspace:*",
    "@medyll/idae-csss": "workspace:*",
    "@medyll/idae-dom-events": "workspace:*",
    "@medyll/idae-eslint-config": "workspace:*",
    "@medyll/idae-idbql": "workspace:*",
    "@medyll/idae-query": "workspace:*",
    "@medyll/idae-shared": "workspace:*",
    "@medyll/idae-stator": "workspace:*",
    "@semantic-release/github": "^12.0.6",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/eslint": "^9.6.1",
    "esbuild": "^0.27.5",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.3.18",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "idae",
    "html",
    "templating",
    "html-utils",
    "dom"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scope": "medyll",
  "author": "Lebrun Meddy",
  "dependencies": {
    "@medyll/skiller": "workspace:*",
    "command": "^1.1.1",
    "commander": "^14.0.3",
    "eta": "^4.5.1",
    "ioredis": "^5.10.1",
    "koa": "^3.2.0",
    "koa-connect": "^2.1.1",
    "koa-proxies": "^0.12.4",
    "node-html-parser": "^7.1.0",
    "open": "^11.0.0",
    "selfsigned": "^5.5.0"
  }
}
