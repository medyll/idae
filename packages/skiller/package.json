{
  "name": "@medyll/skiller",
  "version": "2.2.10",
  "type": "module",
  "description": "Skill installer and evaluator for @medyll packages",
  "main": "./dist/lib/index.mjs",
  "types": "./dist/lib/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.mts",
      "import": "./dist/lib/index.mjs"
    }
  },
  "bin": {
    "skiller": "./dist/lib/cli.js",
    "install-skill": "./dist/lib/cli.js",
    "add-skill": "./dist/lib/client-cli.js",
    "create-skill": "./dist/lib/client-cli.js",
    "test-skill": "./dist/lib/test-cli.js",
    "report": "./dist/lib/test-cli.js",
    "optimize": "./dist/lib/test-cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "."
  },
  "scope": "medyll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medyll/idae.git"
  },
  "author": "Lebrun Meddy",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/build.js",
    "package": "node scripts/build.js",
    "prepublishOnly": "node scripts/build.js",
    "prepackage": "node scripts/package-pre.js"
  }
}
