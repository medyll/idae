{
  "name": "@medyll/qoolie",
  "version": "0.0.1",
  "description": "Client database IndexedDB the easy way, add server sync",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "qoolie": "./dist/cli/index.js",
    "add-skill": "./dist/cli/add-skill.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "default": "./dist/vue/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "default": "./dist/devtools/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run",
    "lint": "eslint src",
    "check": "tsc --noEmit",
    "bench": "tsx benchmarks/index.ts",
    "prepackage": "node scripts/package-pre.js"
  },
  "dependencies": {
    "@medyll/skiller": "workspace:*",
    "@medyll/idae-idbql": "workspace:*",
    "@medyll/idae-sync": "workspace:*",
    "commander": "^14.0.3",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "fake-indexeddb": "^6.2.5",
    "react": "^19.2.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue": "^3.5.31"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "keywords": [
    "indexeddb",
    "sync",
    "react",
    "vue",
    "svelte"
  ],
  "author": "Lebrun Meddy",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medyll/idae.git"
  },
  "publishConfig": {
    "access": "public",
    "directory": "."
  },
  "scope": "medyll"
}
